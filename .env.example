# Pick ONE provider (or set LLM_PROVIDER explicitly)
LLM_PROVIDER=groq  # openai | gemini | groq

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# LLM reliability
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SEC=60

# Orchestrator — production latency profile
FOLLOWUP_MODE=end       # end | per_turn
MAX_FOLLOWUPS=1         # max follow-up questions per candidate

# Eval defaults
EVAL_SAMPLE_SIZE=100
EVAL_RANDOM_SEED=42
EVAL_CONCURRENCY=10     # async semaphore — tune to provider rate limits
